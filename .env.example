# DB 接続設定のテンプレート。
# このファイルをコピーして .env を作り、実際の値を記入する:
#   cp .env.example .env
# .env は .gitignore 済みなのでコミットされない。実際のパスワードは .env にだけ書く。

DB_HOST=localhost
DB_PORT=5435
DB_PORT_STANDBY=5436
DB_NAME=rag_dev
DB_USER=devuser
DB_PASSWORD=your_db_password_here

# reembed 中に Primary→Standby へ自動切り替えするためのフラグファイル
DB_FLAG_FILE=/mnt/mtg_rag/.primary_updating

# Google Gemini API キー（RAG エージェント / ルーターを使う場合に必要）
# https://aistudio.google.com/apikey で取得
GOOGLE_API_KEY=your_gemini_api_key_here
