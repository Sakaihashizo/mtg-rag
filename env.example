# MTG RAG システム 環境変数サンプル
# このファイルを .env にコピーして値を設定してください
# .env は .gitignore に含まれており、リポジトリには含まれません

# Google Gemini API キー（RAG エージェントを使う場合に必要）
# https://aistudio.google.com/apikey で取得
GOOGLE_API_KEY=your_gemini_api_key_here

# PostgreSQL 接続設定（Docker で起動する場合はデフォルト値で動作します）
DB_HOST=localhost
DB_PORT=5435
DB_NAME=rag_dev
DB_USER=devuser
DB_PASSWORD=your_db_password_here
